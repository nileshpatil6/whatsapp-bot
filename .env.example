# ─── WhatsApp (Meta Cloud API) ───────────────────────────────────────────────
# From: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token_here
WEBHOOK_VERIFY_TOKEN=choose_any_secret_string_here

# ─── Google Maps ─────────────────────────────────────────────────────────────
# From: console.cloud.google.com → APIs & Services → Credentials
# Enable: Geocoding API only
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Email (OTP verification) ────────────────────────────────────────────────
# Use a Gmail address + App Password (NOT your regular Gmail password)
# Generate at: myaccount.google.com → Security → 2-Step Verification → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# ─── Database ────────────────────────────────────────────────────────────────
# Local: ./data/rideshare.db
# On Render: /data/rideshare.db  (mounted persistent disk)
DB_PATH=./data/rideshare.db

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
