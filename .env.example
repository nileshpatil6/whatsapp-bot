# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# Production only: your server's public URL (e.g. https://loopz.onrender.com)
# Leave blank for development — polling mode is used automatically
TELEGRAM_WEBHOOK_URL=

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/rideshare.db

# ── Google Maps (geocoding + distance) ───────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Admin dashboard ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=loopz@admin
